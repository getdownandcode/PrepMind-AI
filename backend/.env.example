ENV=development
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/prepmind
JWT_SECRET=change-me-to-64-random-chars
JWT_ALG=HS256
JWT_ACCESS_TTL_MIN=60
JWT_REFRESH_TTL_DAYS=14

# Single LLM provider: Google Gemini 2.5 Flash
GEMINI_API_KEY=your-gemini-api-key-here

CHROMA_PATH=./chroma
CORS_ORIGINS=http://localhost:3000
S3_BUCKET=
S3_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
LOG_LEVEL=INFO
SENTRY_DSN=
